      "id": "sheets-state",
      "name": "Read State Tracker",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [340, 580],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "gs_creds",
          "name": "Google Sheets (startupweekend.zilina@gmail.com)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Read current TASKS_v2\nconst tasks = $input.all();\n// Read previous state\nconst prevStateInput = $('Read State Tracker').all();\n\n// Build prev state map: task_id -> {owner_email, status}\nconst prevState = {};\nfor (const row of prevStateInput) {\n  const id = row.json.A;\n  if (id) prevState[id] = { owner_email: row.json.B, status: row.json.C };\n}\n\nconst now = new Date().toISOString();\nconst results = [];\nconst updateRows = [];\n\nfor (const task of tasks) {\n  const id = task.json.A;\n  const task_name = task.json.B;\n  const owner_email = task.json.E;\n  const status = task.json.F;\n  const deadline = task.json.H;\n\n  if (!id) continue;\n\n  const prev = prevState[id];\n  const prevOwner = prev ? prev.owner_email : null;\n  const prevStatus = prev ? prev.status : null;\n\n  // CASE 1: New task (new ID, new owner)\n  if (!prevOwner && owner_email) {\n    results.push({\n      json: { id, task_name, owner_email, status, deadline,\n              action: 'new_assignment', change_field: 'owner', new_value: status }\n    });\n  }\n  // CASE 2: Owner changed\n  else if (prevOwner !== owner_email && owner_email) {\n    results.push({\n      json: { id, task_name, owner_email, status, deadline,\n              action: 'owner_changed', change_field: 'owner', prev_value: prevOwner, new_value: owner_email }\n    });\n  }\n  // CASE 3: Status changed\n  else if (prevStatus !== status && status) {\n    results.push({\n      json: { id, task_name, owner_email, status, deadline,\n              action: 'status_changed', change_field: 'status', prev_value: prevStatus, new_value: status }\n    });\n  }\n\n  // Always update state tracker\n  updateRows.push({\n    A: id, B: owner_email || prevOwner, C: status || prevStatus, D: now\n  });\n}\n\nreturn results.length > 0 ? results : [{ json: { message: 'no_changes', count: 0 } }];"
      },
      "id": "code-detect",
      "name": "Detect Changes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [580, 440]
    },
    {
      "parameters": {
        "jsCode": "// Rebuild full state tracker from current TASKS_v2\nconst tasks = $input.all();\nconst now = new Date().toISOString();\nconst rows = [];\n\nfor (const task of tasks) {\n  const id = task.json.A;\n  if (!id) continue;\n  rows.push({\n    A: id,\n    B: task.json.E || '',\n    C: task.json.F || '',\n    D: now\n  });\n}\n\nreturn rows.map(r => ({ json: r }));"
      },
      "id": "code-state",
      "name": "Rebuild State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [580, 300]
    },
