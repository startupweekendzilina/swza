    {
      "parameters": {
        "jsCode": "// Filter tasks that are stale (>3 days old since last update or reminder)\n// Read all tasks still in todo/in_progress/blocked/postponed\n// Filter to those where no reminder sent in past 3 days\n\nconst tasks = $input.all();\nconst now = new Date();\nconst threeDaysAgo = new Date(now.getTime() - 3 * 24 * 60 * 60 * 1000);\n\nconst staleTasks = tasks.filter(task => {\n  const status = task.json.F;\n  if (status === 'done' || status === 'cancelled') return false;\n  // For MVP: just send reminder for all non-done tasks)\n  const owner_email = task.json.E;\n  return owner_email && owner_email.includes('@');\n});\n\nreturn staleTasks.map(t => ({\n  json: {\n    id: t.json.A,\n    task_name: t.json.B,\n    owner_email: t.json.E,\n    status: t.json.F,\n    deadline: t.json.H\n  }\n}));"
      },
